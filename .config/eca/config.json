{
    "$schema": "https://eca.dev/config.json",
    "defaultModel": "openai/gpt-5.4-thinking",
    "prompts": {
        "tools": {
            "eca__shell_command": "${file:/home/avelazqu/.config/eca/prompts/tools/shell_command.md}"
        }
    },
    "toolCall": {
        "approval": {
            "byDefault": "allow",
            "ask": {
                "eca__shell_command": {
                    "argsMatchers": {
                        "command": [
                            ".*[12&]?>>?\\s*(?!/dev/null($|\\s))(?!&\\d+($|\\s))\\S+.*",
                            ".*\\b(rm|mv|cp)\\b.*",
                            ".*\\bfind\\b.*\\s-delete\\b.*",
                            ".*\\brsync\\b.*\\s--delete\\b.*",
                            ".*\\bsudo\\b.*",
                            ".*\\bgit\\s+(reset|clean|rebase)\\b.*"
                        ]
                    }
                }
            }
        },
        "outputTruncation": {
            "lines": 5000,
            "sizeKb": 200
        }
    },
    "providers": {
        "openai": {
            "models": {
                "gpt-5.4-thinking": {
                    "modelName": "gpt-5.4",
                    "extraPayload": {
                        "reasoning": {
                            "effort": "xhigh"
                        }
                    }
                }
            }
        }
    }
}
